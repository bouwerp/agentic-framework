{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "permission": {
    "*": "allow"
  },
  "agent": {
    "orchestrator": {
      "description": "Orchestrator agent that coordinates tasks between Worker and Validator agents. Breaks down complex tasks, delegates to workers, and validates results before completion. Uses Figma tools for design analysis during planning.",
      "mode": "primary",
      "model": "openrouter/moonshotai/kimi-k2.5",
      "fallback": "openrouter/moonshotai/kimi-k2-0905",
      "temperature": 0.3,
      "steps": 50,
      "tools": {
        "task": true,
        "read": true,
        "bash": true,
        "grep": true,
        "glob": true,
        "figma-rest": true,
        "figma-oauth": true
      },
      "permission": {
        "*": "allow"
      }
    },
    "worker": {
      "description": "Worker agent that implements code changes and large-scale refactors using GSR (Global Search & Replace). Always previews changes with dryRun before applying.",
      "mode": "subagent",
      "model": "openrouter/qwen/qwen3-coder",
      "fallback": "openrouter/qwen/qwen3-coder-30b-a3b-instruct",
      "temperature": 0.2,
      "steps": 30,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true,
        "glob": true,
        "grep": true,
        "gsr": true,
        "figma-rest": true,
        "figma-oauth": true
      },
      "permission": {
        "*": "allow"
      }
    },
    "validator": {
      "description": "Validator agent that reviews Worker's changes. Uses GSR Preview mode (dryRun) to verify proposed refactors before approval. Read-only access.",
      "mode": "subagent",
      "model": "openrouter/qwen/qwen3-coder",
      "fallback": "openrouter/qwen/qwen3-coder-30b-a3b-instruct",
      "temperature": 0.1,
      "steps": 20,
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "gsr": true,
        "bash": true,
        "figma-rest": true
      },
      "permission": {
        "*": "allow"
      }
    }
  }
}
